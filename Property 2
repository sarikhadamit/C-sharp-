using System;

class Student 
{
    
    private int roll;
    private string name;

    
    public int Roll 
    {
        get { return roll; }
        set { roll = value; }
    }

    
    public string Name 
    {
        get { return name; }
        set { name = value; }
    }

    public void Display() 
    {
        Console.WriteLine("Roll Number : " + roll);
        Console.WriteLine("Name        : " + name);
    }
}

class Program 
{
    static void Main(string[] args) 
    {
      
        Student s = new Student();
        
    
        s.Roll = 168;
        s.Name = "Maulik";
        
        
        s.Display();
    }
}
